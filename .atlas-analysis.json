  "keyFeatures": [
    "Four timeline types: Year, Month, Week, and Custom date ranges",
    "Stoic grid visualization where each dot represents one day",
    "iOS home screen and lock screen widgets for at-a-glance time tracking",
    "Dark-mode-first design with multiple color themes",
    "Local-first data storage with AsyncStorage",
    "Auto-updating Week timelines that refresh to current week",
    "RevenueCat integration for premium subscription features",
    "Firebase-ready data structure for future cloud sync",
    "Expo Router file-based navigation system",
    "Custom native iOS module for App Groups widget data sharing"
  ],
  "publicApiSurface": [
    "Timeline (interface): Core data model for all timeline types",
    "TimelineType (enum): YEAR, MONTH, WEEK, CUSTOM",
    "AppSettings (interface): User preferences for theme and grid colors",
    "loadTimelines(): Load all timelines from AsyncStorage",
    "saveTimeline(timeline): Save or update a timeline",
    "getActiveTimeline(): Get the currently active timeline",
    "setActiveTimeline(id): Set a timeline as active",
    "deleteTimeline(id): Delete a timeline by ID",
    "createTimeline(type, options): Create a new timeline object",
    "calculateTimelineStats(timeline): Calculate days passed/remaining/total",
    "updateTimelineIfNeeded(timeline): Auto-update week/month/year timelines",
    "getDaysPassed(startDate, endDate): Calculate days passed",
    "getTotalDays(startDate, endDate): Calculate total days in range",
    "getProgressPercentage(startDate, endDate): Calculate 0-100 progress",
    "StoicGrid (component): Grid visualization component",
    "TimelineCard (component): Timeline list item with progress",
    "TimelineFormDrawer (component): Timeline creation/editing form",
    "syncActiveTimelineToWidget(): Sync active timeline to iOS widgets",
    "isPro(): Check if user has premium subscription"
  ]
}
